{
  "name": "Retreat Lead",
  "module": "HealVN",
  "doctype": "DocType",
  "engine": "InnoDB",
  "track_changes": 1,
  "show_name_in_global_search": 1,
  "search_fields": "full_name,email,status,priority",
  "title_field": "full_name",
  "autoname": "naming_series:",
  "naming_series": "LEAD-.YYYY.-.#####",
  "fields": [
    {"fieldname": "full_name", "fieldtype": "Data", "label": "Full Name", "reqd": 1, "in_list_view": 1},
    {"fieldname": "email", "fieldtype": "Data", "label": "Email", "options": "Email", "in_list_view": 1},
    {"fieldname": "phone", "fieldtype": "Phone", "label": "Phone"},
    {"fieldname": "column_break_1", "fieldtype": "Column Break"},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status",
     "options": "New\nContacted\nInterested\nNegotiating\nConverted\nLost",
     "default": "New", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "priority", "fieldtype": "Select", "label": "Priority",
     "options": "Cold\nCool\nWarm\nHot", "read_only": 1, "in_list_view": 1},
    {"fieldname": "lead_score", "fieldtype": "Int", "label": "Lead Score (0-100)", "read_only": 1, "in_list_view": 1},
    {"fieldname": "source", "fieldtype": "Select", "label": "Source",
     "options": "\nWebsite\nAI Chat\nTikTok\nInstagram\nFacebook\nGoogle\nReferral\nCorporate\nEvent\nPartner",
     "in_standard_filter": 1},
    {"fieldname": "section_interests", "fieldtype": "Section Break", "label": "Interests"},
    {"fieldname": "interested_retreat", "fieldtype": "Link", "label": "Interested Retreat", "options": "Retreat"},
    {"fieldname": "estimated_budget", "fieldtype": "Currency", "label": "Estimated Budget"},
    {"fieldname": "preferred_dates", "fieldtype": "Date", "label": "Preferred Dates"},
    {"fieldname": "preferred_duration", "fieldtype": "Int", "label": "Preferred Duration (Days)"},
    {"fieldname": "column_break_interest", "fieldtype": "Column Break"},
    {"fieldname": "num_guests", "fieldtype": "Int", "label": "Number of Guests", "default": 1},
    {"fieldname": "preferred_province", "fieldtype": "Link", "label": "Preferred Province", "options": "Territory"},
    {"fieldname": "wellness_goals", "fieldtype": "Small Text", "label": "Wellness Goals"},
    {"fieldname": "dietary_restrictions", "fieldtype": "Data", "label": "Dietary Restrictions"},
    {"fieldname": "section_engagement", "fieldtype": "Section Break", "label": "Engagement"},
    {"fieldname": "ai_chat_sessions", "fieldtype": "Int", "label": "AI Chat Sessions", "default": 0},
    {"fieldname": "retreats_viewed", "fieldtype": "Int", "label": "Retreats Viewed", "default": 0},
    {"fieldname": "last_activity", "fieldtype": "Datetime", "label": "Last Activity"},
    {"fieldname": "column_break_engage", "fieldtype": "Column Break"},
    {"fieldname": "company", "fieldtype": "Data", "label": "Company (if Corporate)"},
    {"fieldname": "nationality", "fieldtype": "Link", "label": "Nationality", "options": "Country"},
    {"fieldname": "special_requests", "fieldtype": "Small Text", "label": "Special Requests"},
    {"fieldname": "section_conversion", "fieldtype": "Section Break", "label": "Conversion", "collapsible": 1},
    {"fieldname": "converted_booking", "fieldtype": "Link", "label": "Converted Booking", "options": "Retreat Booking", "read_only": 1},
    {"fieldname": "erpnext_lead", "fieldtype": "Link", "label": "ERPNext CRM Lead", "options": "Lead", "read_only": 1},
    {"fieldname": "conversion_date", "fieldtype": "Date", "label": "Conversion Date", "read_only": 1},
    {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes"},
    {"fieldname": "notes", "fieldtype": "Text", "label": "Notes"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "Sales User", "read": 1, "write": 1, "create": 1},
    {"role": "Retreat Manager", "read": 1, "write": 1, "create": 1}
  ]
}
